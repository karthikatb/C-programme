#include <stdio.h>
#include <stdlib.h>
#include <time.h>

#define MAX 50

int main() {
    int n, frames;

    printf("Enter length of reference string: ");
    scanf("%d", &n);

    printf("Enter number of frames: ");
    scanf("%d", &frames);

    int ref[MAX], frame[MAX];
    int i, j, k, faults = 0, found, pos, farthest;

    srand(time(0));

    // Generate random reference string
    printf("\nReference String:\n");
    for (i = 0; i < n; i++) {
        ref[i] = rand() % 10;
        printf("%d ", ref[i]);
    }

    // Initialize frames
    for (i = 0; i < frames; i++)
        frame[i] = -1;

    printf("\n\nOptimal Table:\n\n");

    printf("Ref -> ");
    for (i = 0; i < n; i++)
        printf("%d ", ref[i]);
    printf("\n");

    // Optimal process
    for (i = 0; i < n; i++) {
        found = 0;

        // Check if page exists
        for (j = 0; j < frames; j++) {
            if (frame[j] == ref[i]) {
                found = 1;
                break;
            }
        }

        // If not found → page fault
        if (!found) {
            pos = -1;
            farthest = i + 1;

            for (j = 0; j < frames; j++) {
                int next_use = -1;

                // Find next use of current frame page
                for (k = i + 1; k < n; k++) {
                    if (frame[j] == ref[k]) {
                        next_use = k;
                        break;
                    }
                }

                // If page not used again → replace immediately
                if (next_use == -1) {
                    pos = j;
                    break;
                }

                // Find farthest used page
                if (next_use > farthest) {
                    farthest = next_use;
                    pos = j;
                }
            }

            // If all pages used soon, replace first
            if (pos == -1)
                pos = 0;

            frame[pos] = ref[i];
            faults++;
        }

        // Print frames
        for (k = 0; k < frames; k++) {
            if (frame[k] != -1)
                printf("%d ", frame[k]);
            else
                printf("- ");
        }
        printf("\n");
    }

    printf("\nTotal Page Faults = %d\n", faults);

    return 0;
}

int main() {
    int n, i, time = 0, tq = 3, wt = 0;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    int AT[n], BT[n], rem[n];

    printf("Enter AT and BT:\n");
    for(i = 0; i < n; i++) {
        scanf("%d %d", &AT[i], &BT[i]);
        rem[i] = BT[i];   // remaining time
    }

    int done;
    do {
        done = 1;

        for(i = 0; i < n; i++) {
            if(rem[i] > 0) {
                done = 0;

                if(rem[i] > tq) {
                    time += tq;
                    rem[i] -= tq;
                } else {
                    time += rem[i];
                    wt += time - AT[i] - BT[i];
                    rem[i] = 0;
                }
            }
        }

    } while(!done);

    printf("Average Waiting Time = %.2f\n", (float)wt / n);

    return 0;
}

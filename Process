int main() {
    int n, i;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    int AT[n], BT[n], done[n];

    printf("Enter Arrival Time and Burst Time:\n");
    for(i = 0; i < n; i++) {
        scanf("%d %d", &AT[i], &BT[i]);
        done[i] = 0;   // not completed
    }

    int time = 0, completed = 0;
    float wt = 0;

    while(completed < n) {
        int min = -1;

        // Find process with smallest BT among arrived
        for(i = 0; i < n; i++) {
            if(!done[i] && AT[i] <= time) {
                if(min == -1 || BT[i] < BT[min])
                    min = i;
            }
        }

        // If no process has arrived yet
        if(min == -1) {
            time++;
            continue;
        }

        // Calculate waiting time
        wt += time - AT[min];

        // Execute process
        time += BT[min];

        done[min] = 1;
        completed++;
    }

    printf("Average Waiting Time = %.2f\n", wt / n);

    return 0;
}

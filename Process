int main() {
    int n, i, j;

    printf("Enter number of processes: ");
    scanf("%d", &n);

    int AT[n], BT[n];

    printf("Enter Arrival Time and Burst Time:\n");
    for(i = 0; i < n; i++) {
        scanf("%d %d", &AT[i], &BT[i]);
    }

    // Sort by Arrival Time (FCFS rule)
    for(i = 0; i < n-1; i++) {
        for(j = i+1; j < n; j++) {
            if(AT[i] > AT[j]) {
                int temp;
                temp = AT[i]; AT[i] = AT[j]; AT[j] = temp;
                temp = BT[i]; BT[i] = BT[j]; BT[j] = temp;
            }
        }
    }

    int time = 0, wt = 0;

    for(i = 0; i < n; i++) {
        if(time < AT[i])
            time = AT[i];

        wt += time - AT[i];
        time += BT[i];
    }

    printf("Average Waiting Time = %.2f\n", (float)wt / n);

    return 0;
}

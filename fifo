#include <stdio.h>
#include <stdlib.h>
#include <time.h>

int main() {
    int n, frames;

    printf("Enter length of reference string: ");
    scanf("%d", &n);

    printf("Enter number of frames: ");
    scanf("%d", &frames);

    int ref[n], frame[frames];
    int i, j, k, pos = 0, faults = 0, found;

    srand(time(0));

    // Generate random reference string
    printf("\nReference String:\n");
    for (i = 0; i < n; i++) {
        ref[i] = rand() % 10;
        printf("%d ", ref[i]);
    }

    // Initialize frames
    for (i = 0; i < frames; i++)
        frame[i] = -1;

    printf("\n\nFIFO Table:\n\n");

    // Print header (reference string on top)
    printf("Ref -> ");
    for (i = 0; i < n; i++)
        printf("%d ", ref[i]);
    printf("\n");

    // FIFO process
    for (i = 0; i < n; i++) {
        found = 0;

        for (j = 0; j < frames; j++) {
            if (frame[j] == ref[i]) {
                found = 1;
                break;
            }
        }

        if (!found) {
            frame[pos] = ref[i];
            pos = (pos + 1) % frames;
            faults++;
        }

        // Print frame status row-wise (like notebook)
        for (k = 0; k < frames; k++) {
            if (frame[k] != -1)
                printf("%d ", frame[k]);
            else
                printf("- ");
        }
        printf("\n");
    }

    printf("\nTotal Page Faults = %d\n", faults);

    return 0;
}

#include <stdio.h>
#include <stdlib.h>
#include <time.h>

#define MAX 50

int main() {
    int n, frames;

    printf("Enter length of reference string: ");
    scanf("%d", &n);

    printf("Enter number of frames: ");
    scanf("%d", &frames);

    int ref[MAX], frame[MAX], recent[MAX]; // renamed
    int i, j, k, faults = 0, found, min;

    srand(time(0));

    // Generate random reference string
    printf("\nReference String:\n");
    for (i = 0; i < n; i++) {
        ref[i] = rand() % 10;
        printf("%d ", ref[i]);
    }

    // Initialize frames
    for (i = 0; i < frames; i++) {
        frame[i] = -1;
        recent[i] = -1;
    }

    printf("\n\nLRU Table:\n\n");

    

    for (i = 0; i < n; i++) {
        found = 0;

        // Check if page is present
        for (j = 0; j < frames; j++) {
            if (frame[j] == ref[i]) {
                found = 1;
                recent[j] = i; // update recent use
                break;
            }
        }

        // If not found → replace LRU
        if (!found) {
            min = 0;
            for (j = 1; j < frames; j++) {
                if (recent[j] < recent[min])
                    min = j;
            }

            frame[min] = ref[i];
            recent[min] = i;
            faults++;
        }

        // Print frames
        for (k = 0; k < frames; k++) {
            if (frame[k] != -1)
                printf("%d ", frame[k]);
            else
                printf("- ");
        }
        printf("\n");
    }

    printf("\nTotal Page Faults = %d\n", faults);

    return 0;
}
